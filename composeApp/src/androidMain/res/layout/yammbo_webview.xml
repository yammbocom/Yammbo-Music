<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A0A"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/yambo_webview_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FF0A0A0A"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/yambo_webview_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:padding="12dp"
            android:src="@drawable/chevron_back"
            android:tint="#FFFFFFFF"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Atrás" />

        <TextView
            android:id="@+id/yambo_webview_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="240dp"
            android:text="Yammbo Music" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/yambo_webview_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        android:progressTint="#FFE50914"
        android:progressBackgroundTint="#FF1A1A1A" />

    <WebView
        android:id="@+id/yambo_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF0A0A0A" />

</LinearLayout>
